# Keystone Analytics — environment variables
# Copy to .env for local dev, or set these in your Vercel project settings.
# Never commit real secrets; .env is gitignored.

# --- Core (required) ---
# Postgres connection string (Neon). Required at build and runtime.
DATABASE_URL=postgresql://user:password@host:5432/database
# Secret used to sign auth tokens. Generate a long random string.
APP_SECRET=change-me-to-a-long-random-string

# --- Email invitations (required to send invites) ---
# Resend API key (server-side only). Create at https://resend.com and verify
# your sending domain (SPF/DKIM/DMARC) before use.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# From address for invite emails. Must be on your verified domain.
EMAIL_FROM=Keystone Analytics <invites@keystonelab.net>
# Public base URL used to build invite links. On Vercel this falls back to
# VERCEL_PROJECT_PRODUCTION_URL if unset, but set it explicitly for a custom domain.
APP_URL=https://analytics.keystonelab.net
